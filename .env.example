NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
NEXT_PUBLIC_STRIPE_PRO_PAYMENT_LINK=
NEXT_PUBLIC_STRIPE_ELITE_PAYMENT_LINK=

# Fitting room — face-swap mannequin (Phase B). Optional: generation is disabled
# until REPLICATE_API_TOKEN is set. REPLICATE_FACESWAP_MODEL overrides the model.
REPLICATE_API_TOKEN=
# Public community model (verified runnable). Commercial models like
# easel/advanced-face-swap are gated and need granted account access.
REPLICATE_FACESWAP_MODEL=codeplugtech/face-swap
# Virtual try-on model: renders a wardrobe garment onto the base body.
REPLICATE_VTON_MODEL=cuuupid/idm-vton
# Optional dev override: a public, cloud-reachable URL Replicate can fetch.
# Leave unset in production — the app resolves base images from the fit-base
# Supabase public bucket. Only needed locally if Supabase storage isn't reachable
# by Replicate during testing.
REPLICATE_BASE_IMAGE_URL=

# Supabase service role key — required for admin base-image uploads (/admin/base-library).
# Find it in: Supabase dashboard > Settings > API > service_role secret.
SUPABASE_SERVICE_ROLE_KEY=
